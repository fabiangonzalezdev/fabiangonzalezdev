#!/usr/bin/env bash
# Instala gemas con Bundler. Si la ruta del repo tiene espacios (p. ej.
# "Fabian Gonzalez"), las extensiones nativas fallan al compilar en vendor/;
# en ese caso usa ~/.cache/ruby-bundle/<nombre-repo>.
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
DEFAULT_BUNDLE="${REPO_ROOT}/vendor/bundle"
BUNDLE_DIR="${DEFAULT_BUNDLE}"

if [[ "${REPO_ROOT}" =~ [[:space:]] ]]; then
  BUNDLE_DIR="${HOME}/.cache/ruby-bundle/$(basename "${REPO_ROOT}")"
  mkdir -p "${BUNDLE_DIR}"
  echo "La ruta del proyecto incluye espacios; usando BUNDLE_PATH=${BUNDLE_DIR}" >&2
fi

cd "${REPO_ROOT}"
bundle config set --local path "${BUNDLE_DIR}"
bundle install
